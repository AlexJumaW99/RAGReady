# ===========================================================================
# RAG Pipeline - Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values.

# Google Gemini API Key (REQUIRED)
GOOGLE_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------------------
# Media Processing Preferences
# ---------------------------------------------------------------------------
# OCR method for images: "gemini" (default, faster) or "tesseract" (offline)
OCR_METHOD=gemini

# Audio transcription method: "gemini" (default, faster) or "whisper" (offline, heavy)
TRANSCRIPTION_METHOD=gemini

# ---------------------------------------------------------------------------
# Processing Limits (tune for M1 8GB RAM)
# ---------------------------------------------------------------------------
# Max file size in MB to store as BYTEA in PostgreSQL (larger files store path only)
MAX_BINARY_MB=50

# Chunk sizes for text splitting
CHUNK_SIZE_TEXT=1000
CHUNK_OVERLAP_TEXT=200
CHUNK_SIZE_CODE=1500
CHUNK_OVERLAP_CODE=200
